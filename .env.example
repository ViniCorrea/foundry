# ============================================================
# ⚠️ IMPORTANTE: Este é um arquivo de EXEMPLO
# ============================================================
# NUNCA coloque credenciais reais neste arquivo!
# Este arquivo é commitado no Git e pode ser público.
#
# Para usar:
# 1. Copie para .env: cp .env.example .env
# 2. Edite .env com suas credenciais reais
# 3. O .env está no .gitignore e NÃO será commitado
# ============================================================

# Azure Service Principal Credentials
# Usado pelo Terraform para autenticar no Azure
ARM_CLIENT_ID="<seu-client-id-aqui>"
ARM_CLIENT_SECRET="<seu-client-secret-aqui>"
ARM_SUBSCRIPTION_ID="<sua-subscription-id-aqui>"
ARM_TENANT_ID="<seu-tenant-id-aqui>"

# Storage Account Access Key (para o backend tfstate)
ARM_ACCESS_KEY="<seu-access-key-aqui>"
